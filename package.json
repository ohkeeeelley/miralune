{
  "name": "miralunebot",
  "version": "1.0.0",
  "description": "A Discord bot for Starina",
  "main": "main.js",
  "scripts": {
    "start": "node main.js",
    "dev": "nodemon main.js",
    "test": "node tests/run_tests.js",
    "deploy-commands": "node deployCommands.js",
    "deploy-commands:global": "node deployCommands.js --global",
    "clear-commands": "node clearCommands.js",
    "clear-commands:conflicts": "node clearCommands.js --conflicts",
    "lint": "eslint . || true",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "install:shards": "node -e \"console.log('Run discord-hybrid-sharding setup if needed')\""
  },
  "author": "Luna",
  "license": "ISC",
  "keywords": [
    "discord-hybrid-sharding",
    "V2",
    "components",
    "v14",
    "discord-bot",
    "componentsV2",
    "miralune",
    "mlp",
    "bakery"
  ],
  "engines": {
    "node": ">=16.9.0"
  },
  "dependencies": {
    "@discordjs/builders": "^1.11.3",
    "@discordjs/opus": "^0.10.0",
    "@discordjs/rest": "^2.4.3",
    "@discordjs/voice": "^0.15.0",
    "axios": "^1.11.0",
    "canvas": "^3.2.3",
    "chalk": "^4.1.2",
    "discord-api-types": "^0.37.119",
    "discord.js": "^14.0.0",
    "discord.js-minesweeper": "^1.1.0",
    "dotenv": "^16.4.7",
    "form-data": "^4.0.0",
    "gif-encoder-2": "^1.0.5",
    "ms": "^2.1.3",
    "node-fetch": "^3.3.2",
    "path": "^0.12.7",
    "prism-media": "^1.3.5",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "eslint": "^8.46.0",
    "nodemon": "^2.0.22",
    "prettier": "^2.8.8"
  }
}
